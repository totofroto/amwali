{
  "rules": {
    ".read": false,
    ".write": false,

    "farms": {
      "$code": {
        ".read": true,
        ".write": true
      }
    },

    "amwali": {
      "$code": {
        ".read":  "auth != null && $code.length >= 16",
        ".write": "auth != null && $code.length >= 16"
      }
    }
  }
}
